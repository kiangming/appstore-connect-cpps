# ── App Store Connect API ─────────────────────────────────────────────────────
#
# OPTION A (Multi-account — recommended):
# Khai báo nhiều accounts dưới dạng JSON array trong 1 env var duy nhất.
# Khi ASC_ACCOUNTS có mặt, các biến ASC_KEY_ID / ASC_ISSUER_ID / ASC_PRIVATE_KEY bên dưới bị bỏ qua.
#
# ASC_ACCOUNTS=[{"id":"acme","name":"Acme Vietnam","keyId":"XXXXXXXXXX","issuerId":"xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx","privateKey":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"}]
#
# Lưu ý:
#   - id: slug tùy ý, unique, không có khoảng trắng (vd: "acme-vn", "internal")
#   - name: tên hiển thị trên UI
#   - privateKey: nội dung file .p8, dùng \n cho newlines bên trong JSON string
#   - Thêm nhiều objects vào array để có nhiều accounts
#
# Ví dụ 5 accounts (thay các giá trị placeholder bằng thông tin thực):
ASC_ACCOUNTS=[{"id":"client-a","name":"Client A","keyId":"AAAAAAAAAA","issuerId":"aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa","privateKey":"-----BEGIN PRIVATE KEY-----\nMIGTAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBHkwdwIBAQQg...\n-----END PRIVATE KEY-----"},{"id":"client-b","name":"Client B","keyId":"BBBBBBBBBB","issuerId":"bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb","privateKey":"-----BEGIN PRIVATE KEY-----\nMIGTAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBHkwdwIBAQQg...\n-----END PRIVATE KEY-----"},{"id":"client-c","name":"Client C","keyId":"CCCCCCCCCC","issuerId":"cccccccc-cccc-cccc-cccc-cccccccccccc","privateKey":"-----BEGIN PRIVATE KEY-----\nMIGTAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBHkwdwIBAQQg...\n-----END PRIVATE KEY-----"},{"id":"client-d","name":"Client D","keyId":"DDDDDDDDDD","issuerId":"dddddddd-dddd-dddd-dddd-dddddddddddd","privateKey":"-----BEGIN PRIVATE KEY-----\nMIGTAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBHkwdwIBAQQg...\n-----END PRIVATE KEY-----"},{"id":"internal","name":"Internal","keyId":"EEEEEEEEEE","issuerId":"eeeeeeee-eeee-eeee-eeee-eeeeeeeeeeee","privateKey":"-----BEGIN PRIVATE KEY-----\nMIGTAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBHkwdwIBAQQg...\n-----END PRIVATE KEY-----"}]

# OPTION B (Single-account — backward compat):
# Dùng khi chỉ có 1 account và không muốn dùng JSON format.
# Bỏ qua nếu đã set ASC_ACCOUNTS ở trên.
#
# ASC_KEY_ID=
# ASC_ISSUER_ID=
# ASC_PRIVATE_KEY=        # nội dung file .p8 (multiline, dùng \n cho newlines)

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Tạo credentials tại: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Danh sách email được phép đăng nhập bằng Google (comma-separated, không có khoảng trắng)
GOOGLE_ALLOWED_EMAILS=user1@gmail.com,user2@company.com

# ── Admin access — TWO SEPARATE MECHANISMS, do NOT conflate ──────────────────
#
# 1) ADMIN_EMAIL + ADMIN_PASSWORD (singular)
#    Legacy password-login form on the login page. Shown only when
#    ADMIN_ENABLE=1. Bypasses Google SSO entirely. Single account.
#
# 2) ADMIN_EMAILS (plural, comma-separated)
#    Google SSO admin whitelist. Emails listed here receive role="admin"
#    in the NextAuth session (see lib/auth.ts isAdminEmail). Required
#    to access /settings (ASC .p8 management page). Without this, Google
#    SSO users silently default to role="member" and /settings redirects
#    home with no error — common setup footgun.
#
#    Changing ADMIN_EMAILS: restart the dev/prod server (NextAuth caches
#    env at startup), then sign out + sign in so a fresh JWT is minted
#    with the updated role. Existing sessions keep the stale role.
#
ADMIN_ENABLE=1
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_EMAILS=

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_TO_FILE=1  → ghi log vào folder /logs (Docker self-host)
# LOG_TO_FILE=0 hoặc không set → chỉ ghi ra console (Vercel / development)
# Log files: logs/asc-client.log | logs/apps.log | logs/cpp-list.log
#            logs/cpp-detail.log | logs/cpp-submit.log | logs/localization.log
#            logs/upload.log
LOG_TO_FILE=0

# ============================================================
# Store Management module
# ============================================================

# Cron endpoints auth (cho Railway cron hit /api/store-submissions/*).
# PR-7 ships one cron-authenticated endpoint:
#   POST /api/store-submissions/sync/gmail    Gmail sync orchestrator (*/5 * * * *)
# The public healthcheck at GET /api/store-submissions/sync/health does NOT
# require this secret — it's intended for UptimeRobot / external monitors.
# Generate: openssl rand -hex 32
# Railway cron jobs send this verbatim in the `X-Cron-Secret` header.
# Empty string or unset → the endpoint returns 500 and refuses to authenticate
# (no fallback match), so this MUST be configured in any environment that
# runs the cron.
CRON_SECRET=

# Gmail token encryption (AES-256-GCM)
# Generate: openssl rand -hex 32
# ⚠ WARNING: NEVER rotate in production — rotate sẽ làm hỏng tất cả stored tokens
GMAIL_ENCRYPTION_KEY=

# Sentry error tracking (Store Management uses this; CPP optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=

# Initial Manager cho Store Management whitelist (seed lần đầu deploy)
STORE_INITIAL_MANAGER_EMAIL=yourname@yourcompany.com

# Timezone (fixed cho Store Management UI + cron schedules)
APP_TIMEZONE=Asia/Ho_Chi_Minh

# Log level
LOG_LEVEL=info
